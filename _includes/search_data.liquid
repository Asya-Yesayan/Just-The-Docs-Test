<script>
  window.search = {
    "docs": [
      {% for page in site.html_pages %}
        {% unless page.url contains '/search/' or page.url contains '/404.html' %}
          {% if page.url contains site.baseurl %}
            {% assign url = page.url | remove_first: site.baseurl %}
          {% else %}
            {% assign url = page.url %}
          {% endif %}
          {
            "id": "{{ forloop.index }}",
            "title": "{{ page.title | escape }}",
            "content": "{{ page.content | strip_html | strip_newlines | replace: '\', '\\\\' | replace: '"', '\"' | replace: '    ', ' ' | replace: '   ', ' ' | replace: '  ', ' ' | replace: '\n', ' ' | replace: '\r', ' ' }}",
            "url": "{{ url }}"
          }
          {% unless forloop.last %},{% endunless %}
        {% endunless %}
      {% endfor %}
    ]
  };
</script>