---
permalink: /search.json
layout: null
---
{
  "docs": [
    {% for page in site.html_pages %}
      {% if page.url contains site.baseurl %}
        {% assign url = page.url | replace: site.baseurl, "" %}
      {% else %}
        {% assign url = page.url %}
      {% endif %}
      {
        "id": "{{ forloop.index }}",
        "title": "{{ page.title | escape }}",
        "content": "{{ page.content | strip_html | strip_newlines | replace: '\', '\\\\' | replace: '"', '\"' | replace: '    ', ' ' | replace: '   ', ' ' | replace: '  ', ' ' | replace: '\n', ' ' | replace: '\r', ' ' }}",
        "url": "{{ url }}"
      }
      {% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}